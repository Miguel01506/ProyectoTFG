<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="{{ asset('logo.svg') }}">
    <title>{% block title %}{% endblock %} - BeFly</title>
    
    <link rel="stylesheet" href="{{ asset('css/base.css') }}">
    
    {% block stylesheets %}{% endblock %}
</head>
<body>

{% if app.user %}
    <aside class="sidebar">
        <div class="brand-logo">
            <a href="{{ path('ctrl_home') }}">
                {{ include('icons/logo.svg') }}
            </a>
        </div>
        
        <nav class="sidebar-links">
            <a href="{{ path('ctrl_home') }}">Inicio</a>
            <a href="{{ path('ctrl_profile') }}">Perfil</a>
            <a href="{{ path('ctrl_viajes') }}">Mis Viajes</a>
            <hr class="sidebar-divider">
            <a href="{{ path('ctrl_logout') }}" class="logout-link">Cerrar sesión</a>
        </nav>
    </aside>
{% endif %}

<main class="{{ app.user ? 'main-content' : '' }}">
    {% block body %}{% endblock %}
</main>

</body>
</html>
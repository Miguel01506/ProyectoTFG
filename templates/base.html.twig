<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}{% endblock %} - BeFly</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: Arial, sans-serif;
            min-height: 100vh;
        }

        /* ── Layout autenticado ── */
        .layout-authenticated {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 250px;
            background-color: #f8f9fa;
            border-right: 1px solid #dbdbdb;
            padding: 20px;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .sidebar .brand-logo {
            font-size: 24px;
            font-weight: 900;
            margin-bottom: 30px;
            padding-left: 10px;
        }

        .sidebar a {
            display: block;
            padding: 12px 10px;
            color: #262626;
            text-decoration: none;
            font-weight: bold;
            margin-bottom: 4px;
            border-radius: 8px;
        }

        .sidebar a:hover {
            background-color: #efefef;
        }

        .sidebar .logout-link {
            color: red;
            margin-top: auto;
        }

        /* ── Layout público ── */
        .layout-public {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .public-header {
            background-color: #f8f9fa;
            border-bottom: 1px solid #dbdbdb;
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .public-header .brand-logo {
            font-size: 24px;
            font-weight: 900;
        }

        .public-header .brand-logo a {
            text-decoration: none;
            color: #262626;
        }

        .public-header nav a {
            color: #262626;
            text-decoration: none;
            font-weight: bold;
            margin-left: 20px;
            font-size: 14px;
        }

        .main-content-auth {
            margin-left: 250px;
            padding: 40px;
            flex-grow: 1;
            width: calc(100% - 250px);
        }

        .main-content-public {
            flex-grow: 1;
            padding: 40px;
        }
    </style>
</head>
<body>

{% if app.user %}

    {# Sidebar fuera del main, sólo estructura visual #}
    <aside class="sidebar">
        <div class="brand-logo">
            <a href="{{ path('ctrl_home') }}" style="text-decoration: none; color: black;">BeFly</a>
        </div>
        <a href="{{ path('ctrl_home') }}">Inicio</a>
        <a href="{{ path('ctrl_profile') }}">Perfil</a>
        <a href="{{ path('ctrl_viajes') }}">Mis Viajes</a>
        <hr style="margin: 20px 0; border: 0; border-top: 1px solid #dbdbdb;">
        <a href="{{ path('ctrl_logout') }}" class="logout-link">Cerrar sesión</a>
    </aside>

{% else %}

    <header class="public-header">
        <div class="brand-logo">
            <a href="{{ path('ctrl_home') }}">BeFly</a>
        </div>
        <nav>
            <a href="{{ path('ctrl_login') }}">Iniciar sesión</a>
            <a href="{{ path('ctrl_registro') }}">Registrarse</a>
        </nav>
    </header>

{% endif %}

{# ── Un único bloque body, fuera del if ── #}
<main class="{{ app.user ? 'main-content-auth' : 'main-content-public' }}">
    {% block body %}{% endblock %}
</main>

</body>
</html>
{% extends "base.html.twig" %}
{% block title %}Feed Aura
{% endblock %}
{% block body %}
	<h1>Feed Aura</h1>

	{%for post in posts %}
		<div>
			<p>
				<b>{{ post.autor.nombreUsuario }}</b>
				ha publicado en
				<a href="{{ path('ctrl_detalles_viaje', {'id': post.viaje.idViaje}) }}">
					<b>{{ post.viaje.nombre }}</b>
				</a>

				{{ post.fechaPublicacion|date('d/m/Y H:i') }}
			</p>

			<a href="{{ path('ctrl_postDetalle', {'id': post.id}) }}">
				<p>{{ post.texto }}</p>
			</a>

			{% if post.postMedia is not empty %}
				<a href="{{ path('ctrl_postDetalle', {'id': post.id}) }}">
					<small>
						Contiene
						{{ post.postMedia|length }}
						archivos
					</small>
				</a>
			{% endif %}

			<p>
				<small>{{ post.comentarios|length }}
					comentarios</small>
				|
				{% set totalLikes = 0 %}
				{% set totalDislikes = 0 %}

				{% for reac in post.reacciones %}
					{% if reac.tipo == 'like' %}
						{% set totalLikes = totalLikes + 1 %}
					{% elseif reac.tipo == 'dislike' %}
						{% set totalDislikes = totalDislikes + 1 %}
					{% endif %}
				{% endfor %}

				<div class="bloque-reacciones">
					<a href="{{ path('ctrl_reaccionar', {'id': post.id, 'tipo': 'like'}) }}" class="enlace-reaccion">
						<span class="likes-count">{{ totalLikes }}</span> 👍
					</a>

					&nbsp;&nbsp;&nbsp;

					<a href="{{ path('ctrl_reaccionar', {'id': post.id, 'tipo': 'dislike'}) }}" class="enlace-reaccion">
						<span class="dislikes-count">{{ totalDislikes }}</span> 👎
					</a>
				</div>

			</p>
		</div>
	{% else %}
		<p>No hay ninguna publicación todavía.</p>
	{% endfor %}
	<script src="{{ asset('controllers/reaccionesJson.js') }}" defer></script>
{% endblock %}

{% extends "base.html.twig" %}

{% block title %}Feed Aura{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/posts.css') }}">
{% endblock %}

{% block body %}
    <div class="feed-container">
        
        <h1 style="color: var(--color-verde-oscuro, #546B41); font-family: var(--fuente-titulos, serif); margin-bottom: 30px; text-align: center;">FEED AURA</h1>

        {% if posts is not empty %}
            <div class="feed-posts-list">
                {% for post in posts %}
                    <div class="post-card">
                        
                        <p class="post-header">
                            <b>{{ post.autor.nombreUsuario }}</b> ha publicado en 
                            <a href="{{ path('ctrl_detalles_viaje', {'id': post.viaje.idViaje}) }}">
                                <b>{{ post.viaje.nombre }}</b>
                            </a><br>
                            <small class="post-fecha">{{ post.fechaPublicacion|date('d/m/Y H:i') }}</small>
                        </p>

                        <a href="{{ path('ctrl_postDetalle', {'id': post.id}) }}" class="post-body-link">
                            <p class="post-texto">{{ post.texto }}</p>
                        </a>

                        {# CARRUSEL MULTIMEDIA DEL POST #}
                        {% if post.postMedia is not empty %}
                            <div class="post-media-carousel">
                                
                                {% if post.postMedia|length > 1 %}
                                    <button class="btn-media-carrusel btn-media-prev">&#10094;</button>
                                {% endif %}

                                <div class="media-track">
                                    {% for pm in post.postMedia %}
                                        <div class="media-slide">
                                            {% if pm.media.tipo in ['jpg', 'jpeg', 'png', 'gif', 'webp'] %}
                                                <img src="{{ asset('posts/' ~ pm.media.rutaArchivo) }}" alt="Imagen" class="media-item">
                                            {% elseif pm.media.tipo in ['mp4', 'mov', 'avi'] %}
                                                <video controls class="media-item">
                                                    <source src="{{ asset('posts/' ~ pm.media.rutaArchivo) }}" type="video/{{ pm.media.tipo == 'mov' ? 'quicktime' : pm.media.tipo }}">
                                                </video>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                </div>

                                {% if post.postMedia|length > 1 %}
                                    <button class="btn-media-carrusel btn-media-next">&#10095;</button>
                                    
                                    <div class="media-dots">
                                        {% for pm in post.postMedia %}
                                            <span class="media-dot" data-slide-index="{{ loop.index0 }}"></span>
                                        {% endfor %}
                                    </div>
                                {% endif %}

                            </div>
                        {% endif %}

                        <div class="post-interacciones">
                            {% set totalLikes = 0 %}
                            {% set totalDislikes = 0 %}

                            {% for reac in post.reacciones %}
                                {% if reac.tipo == 'like' %}
                                    {% set totalLikes = totalLikes + 1 %}
                                {% elseif reac.tipo == 'dislike' %}
                                    {% set totalDislikes = totalDislikes + 1 %}
                                {% endif %}
                            {% endfor %}

                            <div class="bloque-reacciones" style="display: flex; align-items: center; gap: 20px; margin-top: 5px;">
                                <a href="{{ path('ctrl_reaccionar', {'id': post.id, 'tipo': 'like'}) }}" class="enlace-reaccion" style="text-decoration: none; color: inherit; display: flex; align-items: center; gap: 5px;">
                                    <span class="likes-count" style="font-weight: 600;">{{ totalLikes }}</span> 👍
                                </a>

                                <a href="{{ path('ctrl_reaccionar', {'id': post.id, 'tipo': 'dislike'}) }}" class="enlace-reaccion" style="text-decoration: none; color: inherit; display: flex; align-items: center; gap: 5px;">
                                    <span class="dislikes-count" style="font-weight: 600;">{{ totalDislikes }}</span> 👎
                                </a>

                                <span style="margin-left: auto; font-size: 14px; color: var(--color-verde-oscuro, #546B41);">
                                    <small>{{ post.comentarios|length }} comentarios</small>
                                </span>
                            </div>
                        </div>

                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p style="text-align: center; color: #888;">No hay ninguna publicación todavía.</p>
        {% endif %}

    </div>

    <script src="{{ asset('controllers/posts.js') }}"></script>
    <script src="{{ asset('controllers/reaccionesJson.js') }}" defer></script>
{% endblock %}
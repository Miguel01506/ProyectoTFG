{% extends "base.html.twig" %}
{% block title %}Registro{% endblock %}
{% block body %}
    {% if error is defined and error is not null %}
        <div style="color: red;">
            {{ error }}
        </div>
    {% endif %}
    {% if success is defined and success is not null %}
        <div style="color: green;">
            {{ success }}
        </div>
    {% endif %}
    <h1>Registro de nuevo usuario</h1>

    <form action="{{ path('ctrl_procesar_registro') }}" method="post">

        <label for="username">Usuario</label><br>
        <input type="text" id="username" name="username" value="" />
        <br><br>

        <label for="email">Correo electrónico:</label><br>
        <input type="email" id="email" name="email" value="" />
        <br><br>

        <label for="password">Clave:</label><br>
        <input type="password" id="password" name="password" />
        <br><br>

        <label for="password2">Repite la clave:</label><br>
        <input type="password" id="password2" name="password2" />
        <br><br>

        <button type="submit">Registrar</button>
    </form>
    <br>
    <a href="{{ path('ctrl_login') }}">¿Ya tienes cuenta? Inicia sesión</a>
{% endblock %}
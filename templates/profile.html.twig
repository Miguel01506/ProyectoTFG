{% extends "base.html.twig" %}
{% block title %}Login
{% endblock %}
{% block body %}
	{% for mensaje in app.flashes('mensaje') %}
		<div style="color: green;">
			{{ mensaje }}
		</div>
	{% endfor %}

	<h1>Tu Perfil</h1>
	<img src="{{ asset('img/' ~ app.user.fotoPerfil) }}" alt="foto" width="150">

	<p>Bienvenido,
		{{ app.user.nombreUsuario }}!</p>
	<p>Email:
		{{ app.user.email }}</p>
	<p>Seguidores:
		{{ numSeguidores }}</p>
	<p>Siguiendo:
		{{ numSeguidos }}</p>
	<ul>
		{% if app.user.fechaNacimiento %}
			<li>Fecha de nacimiento:
				{{ app.user.fechaNacimiento|date('d-m-Y') }}</li>
		{% endif %}

		{% if app.user.ciudad %}
			<li>Ciudad:
				{{ app.user.ciudad }}</li>
		{% endif %}

		{% if app.user.biografia %}
			<li>Biografía:
				{{ app.user.biografia }}</li>
		{% endif %}
	</ul>
	<a href="{{ path('ctrl_editarProfile') }}">Editar perfil</a>
	<br><br>
	<h3>¿Qué estás pensando?</h3>

	{# {% if posts is not empty %}
				<h3>Posts</h3>
				<hr>
				{% for post in posts %}
					<div>
						<a href="{{ path('ctrl_perfilExterno', {'id': post.usuario.idUsuario}) }}">
							<img src="{{ asset('img/' ~ post.usuario.fotoPerfil) }}" width="25" height="25" style="border-radius:10px;">
							<strong>{{ post.usuario.nombreUsuario }}</strong>
						</a>:
						{{ post.contenido }}
						<br>
						{% if post.imagen %}
							<img src="{{ asset('uploads/posts/' ~ post.imagen) }}" width="150"><br>
						{% endif %}
						{% if post.archivo %}
							<a href="{{ asset('uploads/posts/' ~ post.archivo) }}">{{ post.archivo }}</a><br>
						{% endif %}
						<br>
						<a href="{{ path('ctrl_postDetalle', {'id': post.idPost}) }}">
							Detalles Post
						</a>
						Comentarios:
						{{ numComentarios[post.idPost] ?? 0 }}
					</div>
					<br>
					Fecha de publicación:
					{{ post.fechaPublicacion|date('d/m/Y H:i') }}<br>
					<hr>
				{% endfor %}
	
			{% else %}
				<p>No has publicado nada aún.</p>
			{% endif %}
			<a href="{{ path('ctrl_quierescambiarcontraseñalogueado') }}" style="color: grey;">¿Quieres cambiar tu contraseña?</a>
			<br><br>
			<a href="{{ path('ctrl_cerrarcuenta') }}" style="color: red;">Elimina tu cuenta aquí</a>
			<br>
		#}
{% endblock %}

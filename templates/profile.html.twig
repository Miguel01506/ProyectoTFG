{% extends "base.html.twig" %}
{% block title %}Profile
{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/perfil.css') }}">
{% endblock %}

{% block body %}
{% for mensaje in app.flashes('mensaje') %}
    <div class="flash-mensaje flash-alert" role="alert">{{ mensaje }}</div>
{% endfor %}

<div class="profile-wrapper">

    <div class="profile-header">
        <div class="profile-avatar-wrap">
            <img src="{{ asset('img/' ~ app.user.fotoPerfil) }}" alt="foto">
        </div>
        <div class="profile-info">
            <h1>{{ app.user.nombreUsuario }}</h1>
            <p class="profile-email">{{ app.user.email }}</p>
            <div class="profile-stats">
                <div class="profile-stat">
                    <span class="profile-stat-num">{{ numSeguidores }}</span>
                    <span class="profile-stat-label">Seguidores</span>
                </div>
                <div class="profile-stat">
                    <span class="profile-stat-num">{{ numSeguidos }}</span>
                    <span class="profile-stat-label">Siguiendo</span>
                </div>
            </div>
        </div>
    </div>

    <div class="profile-details">
        {% if app.user.fechaNacimiento %}
            <span class="profile-tag">{{ app.user.fechaNacimiento|date('d-m-Y') }}</span>
        {% endif %}
        {% if app.user.ciudad %}
            <span class="profile-tag">{{ app.user.ciudad }}</span>
        {% endif %}
        {% if app.user.biografia %}
            <span class="profile-tag">{{ app.user.biografia }}</span>
        {% endif %}
    </div>

    <a href="{{ path('ctrl_editarProfile') }}" class="btn-editar-perfil">Editar perfil</a>

    <hr class="profile-divider">

    <h3 class="profile-post-title">¿Qué estás pensando?</h3>

</div>
{% endblock %}
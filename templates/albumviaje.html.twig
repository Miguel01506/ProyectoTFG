{% extends "base.html.twig" %}

{% block title %} Album {% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/album.css') }}">
{% endblock %}

{% block body %}
{% for mensaje in app.flashes('error') %}
    <div class="flash-error flash-alert">{{ mensaje }}</div>
{% endfor %}
{% for mensaje in app.flashes('mensaje') %}
    <div class="flash-mensaje flash-alert">{{ mensaje }}</div>
{% endfor %}

{% if album %}
<div class="album-wrapper">

    <h1>{{ album.viaje.nombre }}</h1>

    <div class="album-upload-card">
        <h2>Subir contenido</h2>
        <form action="{{ path('ctrl_subir_contenido', {'id': album.viaje.idViaje}) }}" method="post" enctype="multipart/form-data">
            <label class="btn-elegir-archivos-album" for="archivosInput">Elegir archivos</label>
            <input type="file" id="archivosInput" name="archivos[]" multiple required style="display:none;">
            <button type="submit" class="btn-subir">Subir</button>
        </form>
    </div>

    <h2 class="album-section-title">Contenido del álbum</h2>

    {% if contenidoAlbum is not empty %}
        <div class="album-media-grid">
            {% for media in contenidoAlbum %}
                <div class="album-media-item">
                    {% if media.tipo == 'foto' %}
                        <img src="{{ asset('uploads/' ~ media.rutaArchivo) }}" alt="Foto del viaje">
                    {% elseif media.tipo == 'video' %}
                        <video muted loop playsinline
                            onmouseenter="this.play()"
                            onmouseleave="this.pause(); this.currentTime=0;">
                            <source src="{{ asset('uploads/' ~ media.rutaArchivo) }}" type="video/mp4">
                        </video>
                    {% endif %}
                    <div class="album-media-actions">
                        <a href="{{ asset('uploads/' ~ media.rutaArchivo) }}" download class="album-media-btn" title="Descargar">↓</a>
                        <a href="{{ path('ctrl_eliminar_contenido', {'id': media.id}) }}" class="album-media-btn">✕</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p class="album-vacio">No hay contenido en el álbum todavía.</p>
    {% endif %}

    <a href="{{ path('ctrl_detalles_viaje', {'id': album.viaje.idViaje}) }}" class="album-volver">← Volver al viaje</a>

</div>
{% else %}
    <p class="album-vacio">No se encontró un álbum para este viaje.</p>
{% endif %}
{% endblock %}
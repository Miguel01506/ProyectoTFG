{% extends "base.html.twig" %}
{% block title %}Login
{% endblock %}
{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('css/login.css') }}">
{% endblock %}
{% block body %}
	{% if error is defined and error is not null %}
		<div style="color: red;">
			Usuario o contraseña incorrectos
		</div>
	{% endif %}
	{% if success is defined and success is not null %}
		<div style="color: green;">
			{{ success }}
		</div>
	{% endif %}
	{% for mensaje in app.flashes('mensaje') %}
		<div style="color: green;">
			{{ mensaje }}
		</div>
	{% endfor %}

	<div class="container">
		{# Panel izquierdo - logo #}
		<div class="left-container">
			<div id="firefly-canvas"></div>
			<div class="logo">
				{{ include('icons/logo.svg') }}
				<span>Donde las aventuras cobran vida.</span>
			</div>
		</div>

		{# Panel derecho - login #}
		<div class="right-container">
			<div class="card-login">
				<h1>Iniciar Sesión</h1>
				<form action="{{ path('ctrl_login') }}" method="post">
					<label for="email">Email</label>
					<input type="text" id="email" name="_username" value="{{ last_email }}"/>

					<label for="password">Contraseña</label>
					<input type="password" id="password" name="_password"/>

					<button type="submit">Iniciar Sesión</button>
				</form>
				<a href="{{ path('ctrl_registro') }}">¿No tienes cuenta? Regístrate aquí</a>
				<a href="{{ path('ctrl_recuperarpass') }}">¿Olvidaste tu contraseña?</a>
			</div>
		</div>
	</div>

	<script>
		(function () {
			function init() {
				var canvas = document.getElementById('firefly-canvas');
				if (!canvas) return;

				var w = canvas.offsetWidth;
				var h = canvas.offsetHeight;

				if (w === 0 || h === 0) {
					requestAnimationFrame(init);
					return;
				}

				var fireflies = [];

				for (var i = 0; i < 8; i++) {
					var el = document.createElement('div');
					var size = Math.random() * 4 + 3;

					el.style.position        = 'absolute';
					el.style.top             = '0';
					el.style.left            = '0';
					el.style.width           = size + 'px';
					el.style.height          = size + 'px';
					el.style.borderRadius    = '50%';
					el.style.backgroundColor = '#f0ff00';
					el.style.boxShadow       = '0 0 12px 3px rgba(240,255,0,0.9)';
					el.style.pointerEvents   = 'none';
					el.style.willChange      = 'transform';
					el.style.opacity         = '1';
					el.style.transition      = 'opacity 0.8s';

					canvas.appendChild(el);

					fireflies.push({
						el : el,
						x  : Math.random() * w,
						y  : Math.random() * h,
						vx : (Math.random() - 0.5) * 0.8,
						vy : (Math.random() - 0.5) * 0.8
					});
				}

				function animate() {
					var cw = canvas.offsetWidth;
					var ch = canvas.offsetHeight;

					for (var j = 0; j < fireflies.length; j++) {
						var f = fireflies[j];

						f.x += f.vx;
						f.y += f.vy;

						if (f.x < 0 || f.x > cw) f.vx *= -1;
						if (f.y < 0 || f.y > ch) f.vy *= -1;

						f.x = Math.max(0, Math.min(f.x, cw));
						f.y = Math.max(0, Math.min(f.y, ch));

						f.el.style.transform = 'translate(' + f.x + 'px, ' + f.y + 'px)';

						if (Math.random() > 0.98) {
							f.el.style.opacity = (Math.random() * 0.4 + 0.6).toString();
						}
					}

					requestAnimationFrame(animate);
				}

				animate();
			}

			window.addEventListener('load', function () {
				setTimeout(init, 100);
			});
		})();
	</script>
{% endblock %}

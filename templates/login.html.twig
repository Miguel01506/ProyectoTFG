{% extends "base.html.twig" %}
{% block title %}Login
{% endblock %}
{% block body %}
	{% if error is defined and error is not null %}
		<div style="color: red;">
			Usuario o contraseña incorrectos
		</div>
	{% endif %}
	{% if success is defined and success is not null %}
		<div style="color: green;">
			{{ success }}
		</div>
	{% endif %}
	{% for mensaje in app.flashes('mensaje') %}
		<div style="color: green;">
			{{ mensaje }}
		</div>
	{% endfor %}
	<h1>Login</h1>

	<form action="{{ path('ctrl_login') }}" method="post">

		<label for="email">Email</label><br>
		<input type="text" id="email" name="_username" value="{{ last_email }}"/>
		<br><br>

		<label for="password">Clave:</label><br>
		<input type="password" id="password" name="_password"/>
		<br><br>

		<button type="submit">login</button>
	</form>
	<a href="{{ path('ctrl_registro') }}">¿No tienes cuenta? Regístrate aquí</a>
	<br><br>
	{# <a href="{{ path('ctrl_recuperarcontraseña') }}">¿Te has olvidado de tu contraseña? Pulsa aquí</a> #}
{% endblock %}

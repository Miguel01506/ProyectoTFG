{% extends "base.html.twig" %}
{% block title %}Editar profile
{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/editarprofile.css') }}">
{% endblock %}

{% block body %}
{% for mensaje in app.flashes('error') %}
    <div class="flash-error flash-alert" role="alert">{{ mensaje }}</div>
{% endfor %}
{% for mensaje in app.flashes('mensaje') %}
    <div class="flash-mensaje flash-alert" role="alert">{{ mensaje }}</div>
{% endfor %}

<div class="profile-edit-wrapper">
    <h1>Editar perfil</h1>

    <form action="{{ path('ctrl_procesaEditarProfile') }}" method="POST" enctype="multipart/form-data">

        <div class="profile-edit-avatar">
            <img src="{{ asset('img/' ~ app.user.fotoPerfil) }}" alt="foto">
            <div class="profile-edit-avatar-info">
                <label for="fotoInput">Foto de perfil</label>
                <label class="btn-elegir-foto" for="fotoInput">Elegir imagen</label>
                <input type="file" name="fotoPerfil" id="fotoInput" style="display:none;">
            </div>
        </div>

        <div class="form-field">
            <label for="fechaNac">Fecha de nacimiento</label>
            <input type="date" id="fechaNac" name="fechaNac">
        </div>

        <div class="form-field">
            <label for="ciudad">Ciudad</label>
            <input type="text" id="ciudad" name="ciudad" value="{{ app.user.ciudad }}" placeholder="Madrid, Sevilla...">
        </div>

        <div class="form-field">
            <label for="bio">Biografía</label>
            <input type="text" id="bio" name="bio" value="{{ app.user.biografia }}" placeholder="Cuenta tu vida aquí...">
        </div>

        <button type="submit">Guardar cambios</button>
    </form>
</div>
{% endblock %}
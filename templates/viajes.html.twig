{% extends "base.html.twig" %}

{% block title %}MIS VIAJES{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/viajes.css') }}">
{% endblock %}

{% block body %}
    <div class="viajes-wrapper">
        
        <header>
            <h1 class="titulo-principal">VIAJES</h1>
            <p class="texto-bienvenida">Panel de gestión de itinerarios para <strong>{{ app.user.nombreUsuario }}</strong></p>
        </header>
        
        {% if app.user %}
            <section class="section-crear">
                <div class="form-crear-viaje">
                    <h2 class="subtitulo-seccion">Nuevo Itinerario</h2>
                    <form action="{{ path('ctrl_crear_viaje') }}" method="post">
                        <label for="nombre">Nombre del Viaje</label>
                        <input type="text" id="nombre" name="nombre" placeholder="Ejemplo: Ruta por el Norte" required>

                        <label for="destino">Destino Principal</label>
                        <input type="text" id="destino" name="destino" placeholder="Ejemplo: Asturias" required>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="fechaInicio">Fecha de Inicio</label>
                                <input type="date" id="fechaInicio" name="fechaInicio" required>
                            </div>
                            <div class="form-group">
                                <label for="fechaFin">Fecha de Finalización</label>
                                <input type="date" id="fechaFin" name="fechaFin" required>
                            </div>
                        </div>

                        <button type="submit" class="btn-crear">REGISTRAR VIAJE</button>
                    </form>
                </div>
            </section>

            <section class="section-lista">
                <h2 class="subtitulo-seccion">Tus Viajes Activos</h2>
                <div class="viajes-grid">
                    {% for viaje in viajes %}
                        <a href="{{ path('ctrl_detalles_viaje', {'id': viaje.idViaje}) }}" class="viaje-card">
                            <h3>{{ viaje.nombre }}</h3>
                            <p><strong>Destino:</strong> {{ viaje.destino }}</p>
                            <p><strong>Fechas:</strong> {{ viaje.fechaInicio|date('d/m/Y') }} - {{ viaje.fechaFin|date('d/m/Y') }}</p>
                            <p><strong>Participantes:</strong> 
                                {% for participante in participantes %}
                                    {% if participante.viaje.idViaje == viaje.idViaje %}
                                        {{ participante.usuario.nombreUsuario }}{% if not loop.last %}, {% endif %}
                                    {% endif %}
                                {% else %}
                                    Sin participantes registrados
                                {% endfor %}
                            </p>
                        </a>
                    {% else %}
                        <div class="mensaje-vacio">
                            No se han encontrado viajes activos en su cuenta.
                        </div>
                    {% endfor %}
                </div>
            </section>
        {% else %}
            <p>Debe iniciar sesión para gestionar sus viajes.</p>
        {% endif %}
    </div>
{% endblock %}